# =========================================================
# BOLEH DI-IGNORE
# File lokal, rahasia, cache, dependency hasil install,
# dan artefak build yang bisa dibuat ulang.
# =========================================================

# Secret dan konfigurasi environment lokal.
.env
.env.*
!.env.example

# Credential Composer lokal.
/auth.json

# Dependency hasil install.
/node_modules
/vendor

# Hasil build dan file runtime frontend.
/public/build
/public/hot
/public/vendor/bootstrap

# Symlink/storage publik hasil command artisan.
/public/storage

# Key, cache, dan file runtime Laravel/PHP.
/storage/*.key
/storage/pail
/.phpunit.cache
.phpunit.result.cache
.phpactor.json
*.log

# Konfigurasi IDE/editor lokal.
/.fleet
/.idea
/.nova
/.vscode
/.zed

# File OS lokal.
.DS_Store
Thumbs.db

# Konfigurasi VM lokal.
Homestead.json
Homestead.yaml

# Catatan lokal/generated selama development.
# Jangan upload file ini ke GitHub karena isinya biasanya berupa
# log perbaikan, instruksi sementara, output debug, atau kredensial.
/ALL_IMPROVEMENTS_COMPLETE.md
/ANSWER_SCALABILITY.md
/BACKUP_FEATURE_COMPLETE.md
/BACKUP_QUICK_REFERENCE.md
/BACKUP_READY.md

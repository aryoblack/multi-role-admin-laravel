# =========================================================
# JANGAN DI-IGNORE
# File sumber, template konfigurasi, lockfile, test, dan
# dokumentasi penting harus tetap bisa masuk Git.
# =========================================================

!.editorconfig
!.env.example
!.gitattributes
!.gitignore
!README.md
!composer.json
!composer.lock
!CHANGELOG.md
!CHANGELOG_TAILWIND.md
!BUILD_INSTRUCTIONS.md
!COMPANY_SETTINGS_GUIDE.md
!DATABASE_BACKUP_GUIDE.md
!DATATABLE_GLOBAL_USAGE.md
!DATATABLE_MODERN_GUIDE.md
!DEPLOYMENT_GUIDE.md
!DOCUMENTATION_INDEX.md
!FAQ_TAILWIND.md
!package.json
!package-lock.json
!phpunit.xml
!QUICK_START.md
!README_TAILWIND.md
!SCALABILITY_REPORT.md
!TAILWIND_CONVERSION_GUIDE.md
!UPDATE_CONTROLLER_BUTTONS.md
!vite.config.js
!artisan
!app/
!bootstrap/
!config/
!database/
!public/
!resources/
!routes/
!tests/
